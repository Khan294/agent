<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Agent demos</title>
    <style>
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f6f7f9;
        color: #172033;
      }
      main {
        max-width: 920px;
        margin: 0 auto;
        padding: 56px 20px;
      }
      h1 {
        font-size: 36px;
        margin: 0 0 10px;
      }
      .grid {
        display: grid;
        gap: 14px;
        margin-top: 28px;
      }
      a {
        display: block;
        padding: 18px;
        border: 1px solid #d9dde6;
        border-radius: 8px;
        background: #fff;
        color: inherit;
        text-decoration: none;
      }
      strong {
        display: block;
        margin-bottom: 6px;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Agent demos</h1>
      <p>Select a configured client demo.</p>
      <div class="grid">
        <% agents.forEach((agent) => { %>
          <a href="/agents/<%= agent.agentKey %>">
            <strong><%= agent.displayName %></strong>
            <span><%= agent.description || "" %></span>
          </a>
        <% }) %>
      </div>
    </main>
  </body>
</html>
