    "ai": "^7.0.4",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.5",
    "@types/node": "^24.9.2",
    "prisma": "6.18.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
